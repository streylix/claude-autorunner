# Copy to .env and fill in real values. docker-compose.yml interpolates these
# into the backend container. .env is gitignored; this template is committed.

# Django signing key. REQUIRED when DEBUG=false (settings.py raises otherwise).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# false = production mode (no tracebacks, no static /media serving). Default false.
DEBUG=false

# Postgres credentials (shared by the db and backend services).
POSTGRES_DB=ccbot
POSTGRES_USER=ccbot
POSTGRES_PASSWORD=change-me

# Optional shared-secret enabling X-CCBOT-API-Token auth on the Django API.
# Leave UNSET to keep the current loopback-only, no-token behavior. Enabling it
# requires every client (frontend fetch helpers + manager-session.js) to send
# the header, so coordinate before turning it on.
# CCBOT_API_TOKEN=
