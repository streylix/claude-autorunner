{
  "name": "auto-injector",
  "version": "1.0.0",
  "description": "Run a fleet of Claude Code sessions in one window: terminal grid, idle-time prompt injection, a manager Claude instance, and a local voice layer (wake word, push-to-talk, spoken notifications)",
  "main": "main.js",
  "author": {
    "name": "streylix"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "terminal",
    "automation",
    "queue",
    "voice",
    "electron"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "dist": "npm run build",
    "rebuild": "electron-rebuild",
    "download-models": "node scripts/download-models.js",
    "postinstall": "electron-rebuild && (node scripts/download-models.js || true)"
  },
  "build": {
    "appId": "com.auto.injector",
    "productName": "Auto-Injector",
    "compression": "normal",
    "publish": null,
    "mac": {
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icons/icon.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!test_env/**/*",
      "!tests/**/*",
      "!backend/**/*",
      "!coverage/**/*",
      "!.git/**/*",
      "!*.log"
    ],
    "directories": {
      "buildResources": ".",
      "output": "dist"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "playwright": "^1.55.0",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.3.0",
    "lucide": "^0.460.0",
    "node-pty": "^1.0.0",
    "vosk-browser": "^0.0.8"
  }
}
