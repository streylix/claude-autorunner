# ───────────────────────────────────────────────────────────────────────────
# CCBOT Discord Voice Bridge — configuration
# Copy this file to `.env` and fill in the three Discord values. The CCBOT_*
# values are inherited automatically from the terminal that launches the bot
# (the auto-injector sets them) — leave them blank unless you run the bridge
# from outside an app terminal.
# ───────────────────────────────────────────────────────────────────────────

# (1) Bot token from https://discord.com/developers/applications -> your app ->
#     Bot -> Reset Token. Keep this secret; .env is gitignored.
DISCORD_BOT_TOKEN=

# (2) The server (guild) ID. Enable Developer Mode in Discord
#     (User Settings -> Advanced), then right-click your server -> Copy Server ID.
DISCORD_GUILD_ID=

# (3) The voice channel ID the bot should join. Right-click the voice channel
#     -> Copy Channel ID (Developer Mode on).
DISCORD_VOICE_CHANNEL_ID=

# Optional: restrict whose speech is forwarded to the manager. Comma-separated
# Discord user IDs. Leave blank to accept every speaker in the channel.
ALLOWED_SPEAKER_IDS=

# ── Backend / control-API endpoints (defaults are correct for this machine) ──
# Django backend (TTS notifications + Whisper transcription), no auth.
BACKEND_URL=http://localhost:8123
# Electron control API (terminal 999). These are normally inherited from the
# launching terminal's env; only set them here if launching the bridge stand-alone.
CCBOT_PORT=
CCBOT_TOKEN=

# ── Behaviour knobs ──
# Manager terminal id. Do not change unless the app's manager id changes.
MANAGER_TERMINAL_ID=999
# How often (ms) to poll the backend for new manager TTS notifications.
TTS_POLL_INTERVAL_MS=1500
# Mark each notification "played" on the backend after we queue it for Discord.
MARK_PLAYED=true
# Silence gap (ms) that ends a single utterance for voice-receive.
SPEECH_END_SILENCE_MS=900
# Ignore utterances shorter than this (ms) — filters coughs / clicks.
MIN_UTTERANCE_MS=400
# Wrap injected text in bracketed-paste so multi-line memos don't submit early.
USE_BRACKETED_PASTE=true
# Optional: forward bridge logs to the app's unified log stream
# (POST /api/logs/frontend/, surfaces in `docker compose logs -f backend`).
FORWARD_LOGS_TO_BACKEND=true
